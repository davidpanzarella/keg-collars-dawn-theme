le-discount-inner h2 {\n    margin: 0;\n    color: #172f28;\n    font-size: clamp(34px, 5vw, 56px);\n    line-height: 1;\n  }\n\n  .bundle-intro {\n    max-width: 720px;\n    margin: 20px auto 38px;\n    font-size: 18px;\n    line-height: 1.6;\n  }\n\n  .bundle-discount-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    gap: 18px;\n  }\n\n  .bundle-discount-card {\n    position: relative;\n    background: #ffffff;\n    border: 1px solid #c9ad78;\n    border-radius: 4px;\n    padding: 34px 20px;\n    box-shadow: 0 8px 22px rgba(23, 47, 40, 0.08);\n  }\n\n  .bundle-discount-card--featured {\n    border: 3px solid #a77b2e;\n    padding-top: 31px;\n  }\n\n  .bundle-best {\n    position: absolute;\n    top: -14px;\n    left: 50%;\n    transform: translateX(-50%);\n    background: #a77b2e;\n    color: #ffffff;\n    padding: 6px 14px;\n    border-radius: 30px;\n    font-size: 11px;\n    font-weight: 700;\n    letter-spacing: 0.1em;\n    white-space: nowrap;\n  }\n\n  .bundle-number {\n    display: flex;\n    width: 68px;\n    height: 68px;\n    margin: 0 auto 18px;\n    align-items: center;\n    justify-content: center;\n    border-radius: 50%;\n    background: #172f28;\n    color: #ffffff;\n    font-size: 36px;\n    font-weight: 700;\n  }\n\n  .bundle-label {\n    color: #172f28;\n    font-size: 16px;\n    font-weight: 700;\n    letter-spacing: 0.06em;\n  }\n\n  .bundle-percent {\n    margin-top: 10px;\n    color: #a77b2e;\n    font-size: clamp(28px, 3vw, 42px);\n    font-weight: 800;\n    line-height: 1;\n  }\n\n  .bundle-note {\n    margin: 30px auto 24px;\n    font-size: 15px;\n    font-weight: 600;\n  }\n\n  .bundle-button {\n    display: inline-block;\n    background: #a77b2e;\n    color: #ffffff;\n    padding: 16px 28px;\n    text-decoration: none;\n    font-size: 15px;\n    font-weight: 700;\n    letter-spacing: 0.06em;\n    transition: transform 0.2s ease, opacity 0.2s ease;\n  }\n\n  .bundle-button:hover {\n    color: #ffffff;\n    opacity: 0.92;\n    transform: translateY(-2px);\n  }\n\n  @media screen and (max-width: 900px) {\n    .bundle-discount-grid {\n      grid-template-columns: repeat(2, 1fr);\n    }\n  }\n\n  @media screen and (max-width: 549px) {\n    .bundle-discount-section {\n      padding: 52px 16px;\n    }\n\n    .bundle-discount-grid {\n      grid-template-columns: 1fr;\n    }\n\n    .bundle-discount-card {\n      padding: 28px 16px;\n    }\n\n    .bundle-discount-card--featured {\n      padding-top: 28px;\n    }\n  }\n</style>",
